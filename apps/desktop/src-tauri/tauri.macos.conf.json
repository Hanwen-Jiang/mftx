{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MFTX",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState",
          "radius": 10
        }
      }
    ]
  }
}
